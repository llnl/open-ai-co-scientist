# Copy to .env (gitignored) and fill in. Keys come ONLY from the environment —
# never write one into code, config.yaml, fixtures, or logs (see AGENTS.md).

# Required for live runs (the app and `make test-all`). Offline `make test` needs no key.
OPENROUTER_API_KEY=

# Optional: only needed when driving the Codex CLI locally.
OPENAI_API_KEY=
